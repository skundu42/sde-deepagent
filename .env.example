# ── Model providers (at least one required) ─────────────────────────────
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
OPENAI_API_KEY=

# ── Git hosting (required only for pushing branches / opening PRs) ──────
GITHUB_TOKEN=
# GITHUB_API_URL=https://api.github.com   # override for GitHub Enterprise

# ── Long-term memory (optional) — self-hosted supermemory ───────────────
# Run `npx supermemory local` (or the docker-compose service); it prints an
# sm_ API key at startup.
# SUPERMEMORY_BASE_URL=http://localhost:6767
# SUPERMEMORY_API_KEY=sm_...

# ── Firecrawl (optional) — JS-rendering scraper for the Resources page ──
# Self-hosted instance (github.com/firecrawl/firecrawl) or cloud API.
# Unset = sde-deepagent's built-in fetcher (static pages only).
# FIRECRAWL_API_URL=http://localhost:3002   # self-hosted (no key needed)
# FIRECRAWL_API_KEY=fc-...                  # or cloud: implies api.firecrawl.dev

# ── Telegram intake (optional) — create a bot via @BotFather ────────────
TELEGRAM_BOT_TOKEN=
# TELEGRAM_ALLOWED_CHATS=12345,67890      # restrict who can create tasks

# ── Slack intake (optional) — Socket Mode app, no public URL needed ─────
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=

# ── Linear intake (optional) — picks up issues labeled "agent" ──────────
LINEAR_API_KEY=
# LINEAR_LABEL=agent
# LINEAR_POLL_SECONDS=30
# LINEAR_WEBHOOK_SECRET=                  # if you also use /webhooks/linear

# ── LLM cost budgets (USD; unset/0 = unlimited) ─────────────────────────
# TASK_BUDGET_USD=5        # abort any single task whose LLM spend exceeds this
# DAILY_BUDGET_USD=50      # pause picking up new tasks once today's spend hits this

# ── Runtime ──────────────────────────────────────────────────────────────
# HOST=127.0.0.1             # non-loopback binds require AUTH_TOKEN
# PORT=8321
# MAX_CONCURRENT_TASKS=2
# TASK_TIMEOUT_SECONDS=3600
# AUTO_FINALIZE=true
# REQUIRE_APPROVAL=true    # hold every task for human review before push/PR
# WORKSPACE_RETENTION=10   # keep N most recent task workspaces on disk

# ── API auth (recommended for any networked deployment) ─────────────────
# Required for Docker/server deployments that bind beyond loopback. Generate
# with: openssl rand -hex 32
# AUTH_TOKEN=

# ── Per-task container sandbox (isolates the agent's shell + egress) ────
# SANDBOX_DEFAULT=false       # default for repos without an explicit `sandbox`
# SANDBOX_IMAGE=python:3.12-slim
# SANDBOX_NETWORK=none        # none | bridge — egress policy inside the sandbox
# SANDBOX_MEMORY=2g
# SANDBOX_CPUS=2

# ── Per-repo secrets (optional) ─────────────────────────────────────────
# Repos can need credentials to run setup/tests. Two ways to supply them
# (mix freely per repo); either way, values are injected only into
# controller-run setup/tests — never the agent's shell — and redacted from all
# output. Prefer sandbox_network: none for repos with secrets.
#
# (1) Enter values in the UI (Codebases → Secrets), encrypted at rest. Needs a
#     master key (any high-entropy string; a data key is derived from it):
# SECRETS_KEY=        # e.g. `openssl rand -hex 32`
#
# (2) Reference a host env var by name in config/repos.yaml, e.g.
#     secrets: { REGISTRY_TOKEN: env:NPM_TOKEN } — put the value here:
# NPM_TOKEN=
# BACKEND_DB_URL=

# ── GitHub PR review → auto-revision (needs GITHUB_TOKEN) ───────────────
# GITHUB_REVIEW_POLLING=false
# GITHUB_REVIEW_POLL_SECONDS=120
